rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /fuelCards/{cardId} {
      // ==== Authz model (no Functions) ====
      // ההרשאות נשענות על Firebase Auth Email של המשתמש:
      // - Admin email: admin@fuelcards-system.com
      // - User emails: <gadud>@fuelcards-system.com

      function isAdmin() {
        return request.auth != null && request.auth.token.email == 'admin@fuelcards-system.com';
      }

      function gadudFromEmail() {
        // מחזיר מחרוזת (או '' אם אין התאמה)
        return request.auth != null &&
          request.auth.token.email is string
          ?
          (request.auth.token.email == '650@fuelcards-system.com' ? '650'
          : request.auth.token.email == '703@fuelcards-system.com' ? '703'
          : request.auth.token.email == '651@fuelcards-system.com' ? '651'
          : request.auth.token.email == '791@fuelcards-system.com' ? '791'
          : request.auth.token.email == '652@fuelcards-system.com' ? '652'
          : request.auth.token.email == '638@fuelcards-system.com' ? '638'
          : request.auth.token.email == '653@fuelcards-system.com' ? '653'
          : request.auth.token.email == '674@fuelcards-system.com' ? '674'
          : '')
          : '';
      }

      function isMyGadudForRead() {
        return request.auth != null
          && gadudFromEmail() != ''
          && resource.data.gadudNumber is string
          && resource.data.gadudNumber == gadudFromEmail();
      }

      function isMyGadudForCreate() {
        return request.auth != null
          && gadudFromEmail() != ''
          && request.resource.data.gadudNumber is string
          && request.resource.data.gadudNumber == gadudFromEmail();
      }

      function isMyGadudForUpdate() {
        // משתמש רגיל לא יכול להעביר כרטיס לגדוד אחר
        return request.auth != null
          && gadudFromEmail() != ''
          && resource.data.gadudNumber is string
          && request.resource.data.gadudNumber is string
          && resource.data.gadudNumber == gadudFromEmail()
          && request.resource.data.gadudNumber == resource.data.gadudNumber;
      }

      function validateFuelCardData(data) {
        return data.keys().hasAll(['cardNumber', 'name', 'phone', 'amount', 'fuelType', 'gadudNumber']) &&
          data.cardNumber is int &&
          data.name is string &&
          data.phone is string &&
          data.amount is int &&
          data.fuelType is string &&
          data.gadudNumber is string &&
          data.name.size() <= 100 &&
          data.phone.size() <= 20 &&
          data.fuelType.size() <= 50 &&
          data.gadudNumber.size() <= 20 &&
          data.amount > 0 &&
          data.amount <= 100000 &&
          data.cardNumber > 0 &&
          data.cardNumber <= 999999999999;
      }

      // ==== Permissions ====
      allow read: if isAdmin() || isMyGadudForRead();

      // כדי להשאיר התנהגות כמו ה-UI: רק מנהל מנפק כרטיסים (Create)
      allow create: if isAdmin() && validateFuelCardData(request.resource.data);

      allow update: if isAdmin() || (isMyGadudForUpdate() && validateFuelCardData(request.resource.data));

      // מחיקה - רק admin
      allow delete: if isAdmin();
    }

    // Collection אחרות - חסום לחלוטין
    match /{document=**} {
      allow read, write: if false;
    }
  }
}




